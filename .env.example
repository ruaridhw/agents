# Copy to .env and fill in. `.env` is gitignored — never commit real values.
# run.sh sources this file with zsh, so QUOTE any value containing spaces.

# ---- Identity / personalisation -------------------------------------------
# Email of the Granola account whose meetings get synced (note-creator filter).
GRANOLA_ACCOUNT_EMAIL=
# First name used in the morning brief headline.
USER_FIRST_NAME=
# IANA timezone for the brief's calendar window.
HOME_TIMEZONE=Europe/London

# ---- Notion targets for the granola-notion sync ----------------------------
# The private Meetings home page and its data source (dedup + create target).
NOTION_MEETINGS_PAGE_ID=
NOTION_MEETINGS_DATA_SOURCE_ID=

# ---- Notion / Todoist task sync ---------------------------------------------
# Full name used for assignee matching in extracted action items.
USER_FULL_NAME=
# The Tasks database's data source (extraction + sync target).
NOTION_TASKS_DATA_SOURCE_ID=
# The Todoist project holding synced tasks ("Notion Meeting actions").
TODOIST_PROJECT_ID=
# Todoist API token. Plain value — see "Connector secrets" below.
TODOIST_TOKEN=

# ---- Connector secrets ------------------------------------------------------
# Plain values, kept current by `scripts/sync-secrets-from-1password.sh`
# (edit that script's manifest to add more). 1Password stays where you
# actually manage these; .env is the last-synced cache jobs read at run time.
# Jobs never call `op` themselves — op reads hung under launchd for reasons
# never confirmed (see git log 2026-07-21); don't reintroduce a runtime op
# dependency without re-diagnosing that first.
#
# notion/granola/linear authenticate separately, via `claude mcp login
# <name>` (cached by the Claude binary, no .env entry). One-time Google
# setup: `python3 scripts/google-oauth.py authorize`.

# Slack: mcp.slack.com only takes USER tokens (bot tokens are rejected).
# Non-rotating xoxp from your own app (read/search user scopes, MCP server
# access enabled).
SLACK_MCP_TOKEN=

# Google: calendarmcp/gmailmcp.googleapis.com reject non-partner OAuth
# clients outright (tested exhaustively — see AGENTS.md), so gcal/gmail are
# in-process tools (runner/google_tools.py) over plain REST, authenticated
# with a token scripts/google-oauth.py mints from this client.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Optional fallback billing ---------------------------------------------
# Leave unset to bill against the Claude subscription via `claude login`.
# Setting this switches ALL runs to pay-as-you-go API billing — decide deliberately.
# ANTHROPIC_API_KEY=
