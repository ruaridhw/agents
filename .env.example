# Copy to .env and fill in. `.env` is gitignored — never commit real values.

# ---- Identity / personalisation -------------------------------------------
# Email of the Granola account whose meetings get synced (note-creator filter).
GRANOLA_ACCOUNT_EMAIL=
# First name used in the morning brief headline.
USER_FIRST_NAME=
# IANA timezone for the brief's calendar window.
HOME_TIMEZONE=Europe/London

# ---- Notion targets for the granola-notion sync ----------------------------
# The private Meetings home page and its data source (dedup + create target).
NOTION_MEETINGS_PAGE_ID=
NOTION_MEETINGS_DATA_SOURCE_ID=

# ---- Connector secrets ------------------------------------------------------
# None currently: every connector is a remote MCP authenticated via OAuth
# (`claude mcp login <name>`), so no tokens live here. If a connector has to
# fall back to a stdio server, its secrets go here (e.g. SLACK_BOT_TOKEN).

# ---- Optional fallback billing ---------------------------------------------
# Leave unset to bill against the Claude subscription via `claude login`.
# Setting this switches ALL runs to pay-as-you-go API billing — decide deliberately.
# ANTHROPIC_API_KEY=
