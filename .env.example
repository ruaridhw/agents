# Copy to .env and fill in. `.env` is gitignored — never commit real values.
# run.sh sources this file with zsh, so QUOTE any value containing spaces.

# ---- Identity / personalisation -------------------------------------------
# Email of the Granola account whose meetings get synced (note-creator filter).
GRANOLA_ACCOUNT_EMAIL=
# First name used in the morning brief headline.
USER_FIRST_NAME=
# IANA timezone for the brief's calendar window.
HOME_TIMEZONE=Europe/London

# ---- Notion targets for the granola-notion sync ----------------------------
# The private Meetings home page and its data source (dedup + create target).
NOTION_MEETINGS_PAGE_ID=
NOTION_MEETINGS_DATA_SOURCE_ID=

# ---- Notion / Todoist task sync ---------------------------------------------
# Full name used for assignee matching in extracted action items.
USER_FULL_NAME=
# The Tasks database's data source (extraction + sync target).
NOTION_TASKS_DATA_SOURCE_ID=
# The Todoist project holding synced tasks ("Notion Meeting actions").
TODOIST_PROJECT_ID=
# 1Password reference to the Todoist API token, read via `op` with the
# service-account token stored in the macOS Keychain (item: op-service-account).
TODOIST_TOKEN_OP_REF=

# ---- Connector secrets ------------------------------------------------------
# notion/granola/linear are remote MCPs authenticated via OAuth
# (`claude mcp login <name>`) — no tokens here. gcal/gmail use Google's remote
# MCP endpoints with tokens minted by scripts/google-oauth.py from your own
# Google OAuth desktop client (one-time: `python3 scripts/google-oauth.py
# authorize`). Optional override of the client JSON path
# (default ~/.config/google/oauth-client.json):
# GOOGLE_OAUTH_CREDENTIALS=

# mcp.slack.com also refuses dynamic client registration but takes a plain
# bearer: create a Slack app with read/search USER token scopes, install it to
# the workspace, and paste the xoxp User OAuth Token here.
SLACK_MCP_TOKEN=

# ---- Optional fallback billing ---------------------------------------------
# Leave unset to bill against the Claude subscription via `claude login`.
# Setting this switches ALL runs to pay-as-you-go API billing — decide deliberately.
# ANTHROPIC_API_KEY=
